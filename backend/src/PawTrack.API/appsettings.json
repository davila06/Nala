{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "@Microsoft.KeyVault(VaultName=pawtrack-kv;SecretName=sql-connection-string)"
  },
  "Jwt": {
    "Issuer": "pawtrack-api",
    "Audience": "pawtrack-app",
    "Key": "@Microsoft.KeyVault(VaultName=pawtrack-kv;SecretName=jwt-signing-key)",
    "AccessTokenExpirationMinutes": 15,
    "RefreshTokenExpirationDays": 30
  },
  "Azure": {
    "Storage": {
      "ConnectionString": "@Microsoft.KeyVault(VaultName=pawtrack-kv;SecretName=storage-connection-string)",
      "PetPhotosContainer": "pet-photos"
    },
    "Vision": {
      "Endpoint": "@Microsoft.KeyVault(VaultName=pawtrack-kv;SecretName=vision-endpoint)",
      "Key": "@Microsoft.KeyVault(VaultName=pawtrack-kv;SecretName=vision-key)"
    },
    "KeyVaultUri": "https://pawtrack-kv.vault.azure.net/"
  },
  "ApplicationInsights": {
    "ConnectionString": "@Microsoft.KeyVault(VaultName=pawtrack-kv;SecretName=appinsights-connection-string)"
  },
  "RateLimiting": {
    "Login": {
      "PermitLimit": 5,
      "WindowSeconds": 60
    },
    "Sightings": {
      "PermitLimit": 5,
      "WindowSeconds": 60
    }
  },
  "Cors": {
    "AllowedOrigins": [
      "https://pawtrack.azurestaticapps.net"
    ]
  },
  "App": {
    "BaseUrl": "https://pawtrack.cr"
  },
  "Broadcast": {
    "WhatsApp": {
      "PhoneNumberId": "@Microsoft.KeyVault(VaultName=pawtrack-kv;SecretName=whatsapp-phone-number-id)",
      "AccessToken": "@Microsoft.KeyVault(VaultName=pawtrack-kv;SecretName=whatsapp-access-token)"
    },
    "Telegram": {
      "BotToken": "@Microsoft.KeyVault(VaultName=pawtrack-kv;SecretName=telegram-bot-token)"
    },
    "Facebook": {
      "PageAccessToken": "@Microsoft.KeyVault(VaultName=pawtrack-kv;SecretName=facebook-page-access-token)",
      "PageId": "@Microsoft.KeyVault(VaultName=pawtrack-kv;SecretName=facebook-page-id)"
    }
  }
}
